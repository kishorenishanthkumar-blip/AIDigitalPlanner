# ─────────────────────────────────────────────────────────────
# DI-Platform — Environment Variables (TEMPLATE)
# Copy this file to `.env` and fill in real values.
# NEVER commit `.env` to git.
# ─────────────────────────────────────────────────────────────

# ── Application ────────────────────────────────────────────
APP_ENV=development           # development | staging | production
APP_NAME=DI-Platform
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
SECRET_KEY=change-me-to-a-long-random-string

# ── Anthropic / AI ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://di_user:di_pass@localhost:5432/di_platform
DB_POOL_SIZE=10
DB_ECHO=false

# ── Redis (cache / queue) ──────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Jira export ────────────────────────────────────────────
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_USER_EMAIL=you@example.com
JIRA_API_TOKEN=xxxxxxxxxxxxxxxxxxxx

# ── Rally export ───────────────────────────────────────────
RALLY_BASE_URL=https://rally1.rallydev.com
RALLY_API_KEY=_xxxxxxxxxxxxxxxxxxxx

# ── Logging ────────────────────────────────────────────────
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json               # json | text
