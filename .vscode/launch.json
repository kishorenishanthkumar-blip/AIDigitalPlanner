{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "DI-Platform — API (uvicorn)",
      "type": "debugpy",
      "request": "launch",
      "module": "di_platform",
      "env": { "PYTHONPATH": "${workspaceFolder}/src" },
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Pytest — current file",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["${file}", "-v"],
      "env": { "PYTHONPATH": "${workspaceFolder}/src" },
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Pytest — all tests",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["tests", "-v"],
      "env": { "PYTHONPATH": "${workspaceFolder}/src" },
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal",
      "justMyCode": false
    }
  ]
}
